{
  "name": "mock-auth-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/mock-auth-server",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "cd packages/mock-auth-server; pnpm run build",
            "forwardAllArgs": false
          }
        ]
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "cd packages/mock-auth-server; pnpm run dev",
            "forwardAllArgs": false
          }
        ]
      }
    }
  }
}
